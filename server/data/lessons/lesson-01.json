  "grammar": [
    {
      "pattern": "N1 は N2 です",
      "explanation": "A is B. 「は」 is the topic particle, and 「です」 means 'is / are / am.'",
      "examples": [
        { "japanese": "わたしは学生です。", "meaning": "I am a student." },
        { "japanese": "田中さんは先生です。", "meaning": "Mr. Tanaka is a teacher." }
      ]
    },
    {
      "pattern": "N1 は N2 ではありません",
      "explanation": "A is not B. Negative form of 「です」.",
      "examples": [
        { "japanese": "わたしは学生ではありません。", "meaning": "I am not a student." },
        { "japanese": "山田さんは医者ではありません。", "meaning": "Mr. Yamada is not a doctor." }
      ]
    },
    {
      "pattern": "N1 は N2 ですか",
      "explanation": "Is A B? Question form: add 「か」 at the end.",
      "examples": [
        { "japanese": "あなたは学生ですか。", "meaning": "Are you a student?" },
        { "japanese": "はい、学生です。", "meaning": "Yes, I am a student." },
        { "japanese": "いいえ、学生ではありません。", "meaning": "No, I am not a student." }
      ]
    },
    {
      "pattern": "N1 の N2",
      "explanation": "The particle 「の」 connects two nouns. N1 modifies N2.",
      "examples": [
        { "japanese": "わたしの名前は田中です。", "meaning": "My name is Tanaka." },
        { "japanese": "大学の先生", "meaning": "A university teacher" }
      ]
    }
