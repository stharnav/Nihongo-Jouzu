# =============================================================================
# Nihongo Jouzu — Environment Variables
# =============================================================================
# Copy this file to .env for local development.
# For Render deployment, set these in the Dashboard → Environment Variables.
# =============================================================================

# ─── Client (Vite) ──────────────────────────────────────────────────────────
# These are exposed to the browser at build time (VITE_ prefix).
# Get them from Firebase Console → Project Settings → Web Apps → Config.
# Render: Set in Dashboard → Environment (they'll be read during build).
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Server (Firebase Admin SDK) ────────────────────────────────────────────
# Choose ONE of the three options below:

# Option A (Render-friendly): Paste the FULL service account JSON as a single value.
#   - Go to Firebase Console → Project Settings → Service Accounts → Generate Key
#   - Copy the entire JSON, minify it, and paste as one line.
#   - Render: Set in Dashboard → Environment as a multiline env var.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option B (Render secret files): Base64-encoded service account JSON.
#   - On your machine:  base64 -i your-key.json | pbcopy  (macOS)
#   - On Render: Store as a Secret File and map to this env var.
# FIREBASE_SERVICE_ACCOUNT_BASE64=<base64_of_service_account_json>

# Option C (Local dev): Path to the downloaded JSON key file.
#   - Defaults to learn-japanese-e60e8-firebase-adminsdk-fbsvc-eef3889a6b.json
#     in the repo root if not set.
FIREBASE_ADMIN_SDK_PATH=./learn-japanese-e60e8-firebase-adminsdk-fbsvc-eef3889a6b.json

# ─── Server ────────────────────────────────────────────────────────────────
PORT=5000
